{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "RAILPACK"
    },
    "deploy": {
        "numReplicas": 1,
        "startCommand": "python main.py",
        "overlapSeconds": 0,
        "drainingSeconds": 10,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}
